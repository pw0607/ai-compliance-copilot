# AI Compliance Copilot — Environment Configuration
# Copy this file to .env and fill in values as needed.

# LLM Mode: set to "true" to use a real LLM instead of mock evaluation
USE_REAL_LLM=false

# OpenAI API key (required only when USE_REAL_LLM=true)
OPENAI_API_KEY=your-api-key-here

# OpenAI model to use (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# FastAPI host and port
API_HOST=0.0.0.0
API_PORT=8000

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
